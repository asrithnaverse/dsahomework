#include<iostream>
using namespace std;
int reverse(int num)
{
    int ans=0;
    int temp, rem;
    temp=num;
    while(temp!=0)
    {
        rem=temp%10;
        ans=ans*10+rem;
        temp/=10;
    }
    return ans;
}
int main()
{
    int a;
    cout<< "Enter the number: ";
    cin>>a;
    cout<<endl;
    cout<<reverse(a);
}
